# Variables de entorno — Empoderamiento Docente
#
# 1. Copiar este archivo: cp .env.example .env.local
# 2. Completar cada variable según el entorno.
# 3. NUNCA commitear .env, .env.local ni similares (ya están en .gitignore).
#
# Las claves listadas acá son las únicas que el código lee. Si necesitás
# sumar una nueva, agregala también en este archivo con un valor de ejemplo
# para que el resto del equipo sepa que existe.

# ── MongoDB ─────────────────────────────────────────────────────────────────
# URI de conexión a la base. Atlas o instancia self-hosted.
# Ejemplo Atlas: mongodb+srv://<usuario>:<password>@<cluster>/<db>?retryWrites=true&w=majority
# Ejemplo local: mongodb://127.0.0.1:27017/empoderamiento-docente
MONGODB_URI=

# Nombre de la base. Default si se omite: "empoderamiento-docente".
MONGODB_DB=empoderamiento-docente

# ── Next.js ─────────────────────────────────────────────────────────────────
# URL pública del sitio (canonical). Vercel la setea automáticamente en
# producción; útil definirla en entornos custom (preview self-hosted, dev).
# NEXT_PUBLIC_SITE_URL=https://empoderamientodocente.org
